# Oracle ATP / UCP local example
DB_USER=
DB_PASSWORD=
TNS_ADMIN=

# Telegram Bot Configuration
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# LLM Configuration (Groq or DeepSeek)
# Get Groq API Key for FREE at: https://console.groq.com/keys
LLM_PROVIDER=groq
LLM_API_KEY=
# Use a Groq model id you have access to.
LLM_MODEL=llama-3.1-8b-instant
LLM_API_URL=https://api.groq.com/openai/v1/
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Selenium E2E (optional)
E2E_BASE_URL=http://localhost:3000
E2E_API_BASE_URL=http://localhost:8080
E2E_BROWSER=edge
E2E_HEADLESS=false