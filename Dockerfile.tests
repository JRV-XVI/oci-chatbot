FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements-test.txt ./requirements-test.txt
RUN pip install -r requirements-test.txt

COPY pytest.ini ./pytest.ini
COPY tests ./tests

# Defaults for containerized execution against Selenium standalone container.
ENV E2E_BROWSER=edge \
    E2E_HEADLESS=true \
    E2E_BASE_URL=http://host.docker.internal:3000 \
    E2E_SELENIUM_REMOTE_URL=http://host.docker.internal:4444/wd/hub \
    E2E_TIMEOUT_SECONDS=25 \
    E2E_ARTIFACTS_DIR=/app/tests/selenium/artifacts

CMD ["sh", "-c", "python tests/selenium/utils/wait_for_url.py \"${E2E_BASE_URL}\" 120 && python tests/selenium/utils/wait_for_url.py \"${E2E_SELENIUM_REMOTE_URL}\" 120 && pytest tests/selenium -m e2e"]
